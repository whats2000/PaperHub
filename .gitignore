# Local reference projects (per design §10, never committed)
reference/

# ===== Python (backend/) =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# Type-checking artifacts
.dmypy.json

# ===== Node / frontend (frontend/) =====
# (frontend/.gitignore covers most of these; the entries here let the root
#  .gitignore stay authoritative if someone runs node tooling outside frontend/)
node_modules/
.npm/
.yarn/
.pnp.*
*.tsbuildinfo
.vite/
.next/

# ===== Runtime data + user-specific paths =====
*.db
*.db-journal
*.sqlite
*.sqlite3
/chroma/
/workspace/
/backend/chroma/
/backend/workspace/
.env
.env.*
!.env.example

# ===== local debug / scratch scripts =====
# Operator-facing live-API harnesses for diagnosing the research pipeline
# against real Gemini + Semantic Scholar + open-webSearch. Per-developer
# scratch files; not part of the project surface area.
backend/scripts/debug_*.py

# ===== OS + editor noise =====
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json

# logs
*.log
*.err
*.out

# workspace files
.*workspace
workspace*/

# local configuration files
*.local.json

# MCP server registry — operator-edited, may reference local-only daemons.
# Checked-in template lives at backend/mcp_servers.toml.example (SRS v2.5,
# §III-6.1).
/backend/mcp_servers.toml
# Sidecar written by paperhub-mcp-up: ports of MCP daemons it started, read by
# scripts/start.ps1 for cleanup on exit.
/backend/.mcp_daemon_ports

# temporary files
tmp*/
_tmp*

# git worktrees (e.g. subagent-driven-development scratch checkouts)
.worktrees/

# Marker service local test artifacts
marker_service/sample.pdf
marker_service/*.local.*
