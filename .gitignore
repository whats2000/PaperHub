# Local reference projects (per design §10, never committed)
reference/

# ===== Python (backend/) =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# Type-checking artifacts
.dmypy.json

# ===== Node / frontend (frontend/) =====
# (frontend/.gitignore covers most of these; the entries here let the root
#  .gitignore stay authoritative if someone runs node tooling outside frontend/)
node_modules/
.npm/
.yarn/
.pnp.*
*.tsbuildinfo
.vite/
.next/

# ===== Runtime data + user-specific paths =====
*.db
*.db-journal
*.sqlite
*.sqlite3
/chroma/
/workspace/
/backend/chroma/
/backend/workspace/
.env
.env.*
!.env.example

# ===== OS + editor noise =====
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json

# logs
*.log
*.err
*.out

# workspace files
.*workspace

# local configuration files
*.local.json
