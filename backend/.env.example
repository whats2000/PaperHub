# Copy to backend/.env (not the repo root) and fill in. The real-flow smoke script loads this file.

# LiteLLM provider credentials. Only the provider matching your chosen models is required.
# Defaults below use gemini/* models, so GEMINI_API_KEY is the relevant one.
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional model overrides (defaults are gemini/gemini-2.5-flash for both).
# PAPERHUB_ROUTER_MODEL=gemini/gemini-2.5-flash
# PAPERHUB_CHITCHAT_MODEL=gemini/gemini-2.5-flash

# Workspace dir for the SQLite db + any future per-run artefacts.
# PAPERHUB_WORKSPACE=./workspace
