# Copy to backend/.env and fill in. Restart backend or rely on --reload.


# 1. Provider credentials
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=


# 2. Workspace + storage
# Workspace root (SQLite, Chroma, papers cache).
# PAPERHUB_WORKSPACE=./workspace
# Max PDF upload size (MiB).
# PAPERHUB_MAX_UPLOAD_MB=30


# 3. LLM model selection
# Router intent classifier.
# PAPERHUB_ROUTER_MODEL=gemini/gemini-3.1-flash-lite
# Chitchat agent.
# PAPERHUB_CHITCHAT_MODEL=gemini/gemini-3.1-flash-lite
# paper_qa finalizer (cross-paper synthesis; streams to user).
# PAPERHUB_PAPER_QA_MODEL=gemini/gemini-3.1-pro-preview
# paper_qa per-paper subagent (section navigation + chunk picking).
# PAPERHUB_PAPER_QA_SUBAGENT_MODEL=gemini/gemini-3.1-flash-lite
# SQL Agent NL2SQL planner + self-repair (small tier).
# PAPERHUB_SQL_AGENT_MODEL=gemini/gemini-3.1-flash-lite
# SQL Agent answer phrasing (flagship tier).
# PAPERHUB_SQL_ANSWER_MODEL=gemini/gemini-2.5-pro
# Slide pipeline (Report Agent, Plan F3) — tiers per LangGraph stage.
# Resolve enabled papers (small tier).
# PAPERHUB_REPORT_RESOLVE_MODEL=gemini/gemini-3.1-flash-lite
# Per-paper understand (PaperBrief) + per-page note split (flagship).
# PAPERHUB_REPORT_NOTES_MODEL=gemini/gemini-2.5-pro
# Narrate the cross-paper TalkOutline (flagship).
# PAPERHUB_REPORT_PLAN_MODEL=gemini/gemini-2.5-pro
# Draft frame+note pairs, coherence pass, Overfull revise (flagship).
# PAPERHUB_REPORT_SECTION_MODEL=gemini/gemini-2.5-pro


# 4. Local embedding + rerank (run in the modelserver process)
# Embedder model.
# PAPERHUB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Cross-encoder reranker.
# PAPERHUB_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Device for embedder + reranker (auto | cpu | cuda | cuda:N | mps).
# PAPERHUB_DEVICE=auto


# 5. Model server
# Modelserver bind address.
# PAPERHUB_MODEL_SERVER_HOST=127.0.0.1
# PAPERHUB_MODEL_SERVER_PORT=8001
# Load models in-process instead of calling the modelserver (tests use 1).
# PAPERHUB_INPROCESS_MODELS=0


# 6. Agent tunables
# Max read_section() calls per per-paper subagent turn.
# PAPERHUB_PAPER_QA_MAX_SECTION_READS=8


# 7. Memory / recall
# Inject recalled memories into paper_qa / library_stats answers (1=on, 0=off).
# PAPERHUB_MEMORY_RECALL=1
# Upgrade path: use semantic (embedding-based) recall instead of FTS. NOT
# implemented yet — leave at 0 until a future plan wires the embedder path.
# PAPERHUB_MEMORY_SEMANTIC=0


# 8. External services
# Semantic Scholar API key (optional; unauth tier is rate-limited).
# PAPERHUB_SEMANTIC_SCHOLAR_API_KEY=


# 9. Logging
# Python log level (DEBUG | INFO | WARNING | ERROR).
# PAPERHUB_LOG_LEVEL=INFO


# 10. External lookup services
# Unpaywall fallback (optional). When set, papers that Semantic
# Scholar can find but doesn't link to a free PDF (e.g. Nature
# papers — the AlphaGenome class) are looked up by DOI on
# Unpaywall. Set this to your contact email — Unpaywall uses it
# for abuse-control logging only.
PAPERHUB_UNPAYWALL_EMAIL=
