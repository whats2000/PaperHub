# Copy to backend/.env and fill in. Restart backend or rely on --reload.


# 1. Provider credentials
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=


# 2. Workspace + storage
# Workspace root (SQLite, Chroma, papers cache).
# PAPERHUB_WORKSPACE=./workspace
# Max PDF upload size (MiB).
# PAPERHUB_MAX_UPLOAD_MB=30


# 3. LLM model selection
# Router intent classifier.
# PAPERHUB_ROUTER_MODEL=gemini/gemini-3.1-flash-lite
# Chitchat agent.
# PAPERHUB_CHITCHAT_MODEL=gemini/gemini-3.1-flash-lite
# paper_qa finalizer (cross-paper synthesis; streams to user).
# PAPERHUB_PAPER_QA_MODEL=gemini/gemini-3.1-pro-preview
# paper_qa per-paper subagent (section navigation + chunk picking).
# PAPERHUB_PAPER_QA_SUBAGENT_MODEL=gemini/gemini-3.1-flash-lite


# 4. Local embedding + rerank (run in the modelserver process)
# Embedder model.
# PAPERHUB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Cross-encoder reranker.
# PAPERHUB_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Device for embedder + reranker (auto | cpu | cuda | cuda:N | mps).
# PAPERHUB_DEVICE=auto


# 5. Model server
# Modelserver bind address.
# PAPERHUB_MODEL_SERVER_HOST=127.0.0.1
# PAPERHUB_MODEL_SERVER_PORT=8001
# Load models in-process instead of calling the modelserver (tests use 1).
# PAPERHUB_INPROCESS_MODELS=0


# 6. Agent tunables
# Max read_section() calls per per-paper subagent turn.
# PAPERHUB_PAPER_QA_MAX_SECTION_READS=5


# 7. External services
# Semantic Scholar API key (optional; unauth tier is rate-limited).
# PAPERHUB_SEMANTIC_SCHOLAR_API_KEY=


# 8. Logging
# Python log level (DEBUG | INFO | WARNING | ERROR).
# PAPERHUB_LOG_LEVEL=INFO
