# PaperHub environment file. Copy to `.env` and fill in the values you actually use.
#
# Loaded by `paperhub.config.get_settings()` via python-dotenv with `override=False`,
# so anything you set in your shell (or pytest's monkeypatch) wins over what's here.
# LiteLLM reads provider API keys from os.environ — `get_settings()` exports the
# typed `*_api_key` fields back to os.environ on startup so the same key works
# whether you set the prefixed form (PAPERHUB_GEMINI_API_KEY) or the bare form
# (GEMINI_API_KEY).

# ===== Required: workspace paths =====
# Where PaperHub stores downloaded papers, the SQLite DB, the Chroma collection,
# and slide artifacts. Pick a directory you own; it'll be created if missing.
PAPERHUB_WORKSPACE_ROOT=./.paperhub-workspace
PAPERHUB_DB_PATH=./.paperhub-workspace/paperhub.db

# ===== LLM provider API key =====
# Set ONE that matches the model IDs below. LiteLLM routes by the model-ID prefix
# (`gemini/...` -> uses GEMINI_API_KEY; `claude-...` -> ANTHROPIC_API_KEY; etc.).

# Gemini (recommended default preset — see model IDs below):
GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude:
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI:
# OPENAI_API_KEY=sk-...

# ===== Model picks =====
# LiteLLM model IDs. Pick a provider-matching trio. The judge model MUST be
# different from the generation model (FR-12 constraint: avoid judge/generator
# collusion in the eval harness).

# Gemini preset (matches GEMINI_API_KEY above):
PAPERHUB_ROUTER_MODEL=gemini/gemini-2.5-flash
PAPERHUB_GENERATION_MODEL=gemini/gemini-2.5-pro
PAPERHUB_JUDGE_MODEL=gemini/gemini-2.5-flash

# Anthropic preset (used if you swap ANTHROPIC_API_KEY in above):
# PAPERHUB_ROUTER_MODEL=claude-haiku-4-5
# PAPERHUB_GENERATION_MODEL=claude-sonnet-4-6
# PAPERHUB_JUDGE_MODEL=claude-haiku-4-5

# OpenAI preset:
# PAPERHUB_ROUTER_MODEL=gpt-4o-mini
# PAPERHUB_GENERATION_MODEL=gpt-4o
# PAPERHUB_JUDGE_MODEL=gpt-4o-mini

# ===== Embedding & reranker (local sentence-transformers) =====
# These models download from HuggingFace on first use (~80 MB for bge-small).
# Cached locally afterwards; no API key needed.
# PAPERHUB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# PAPERHUB_RERANKER_MODEL=BAAI/bge-reranker-base

# ===== Vector backend =====
# `chroma` (default) is recommended on Windows — clean wheels, no native build.
# `sqlite-vec` is opt-in (everything in one .db file). Both implement the same
# interface; switching is a one-flag change.
# PAPERHUB_VECTOR_BACKEND=chroma
# PAPERHUB_CHROMA_PATH=          # if blank, defaults to ${WORKSPACE_ROOT}/chroma

# ===== MCP tool launch commands =====
# How PaperHub spawns each MCP server. `uvx` (from uv) auto-fetches the package.
# PAPERHUB_MCP_ARXIV_COMMAND=uvx arxiv-mcp-server
# PAPERHUB_MCP_FILESYSTEM_COMMAND=npx -y @modelcontextprotocol/server-filesystem

# ===== GROBID =====
# Optional in Phase A — the arxiv-mcp-server returns markdown directly, so
# GROBID isn't called during import. Phase B (citation graph) needs it.
# PAPERHUB_GROBID_URL=http://localhost:8070

# ===== Ollama (local LLM fallback) =====
# Not used by Phase A's default config but supported by LiteLLM if you want a
# fully-offline path (e.g. `ollama/llama3.1`).
# PAPERHUB_OLLAMA_BASE_URL=http://localhost:11434
